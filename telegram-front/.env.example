# Copiar a .env.development o .env.production y completar valores reales solo en tu máquina o en el servidor (no subir esos archivos).

# URL base del API Node (sin barra final).
#   - Local: http://127.0.0.1:4001
#   - Producción (Netlify): https://TU-SERVICIO.onrender.com
VITE_API_BASE_URL=https://your-service.onrender.com

# Si el proxy publica el API bajo un prefijo (ej. apis/infobot), sin barras al inicio/fin.
# En Render este prefijo no se usa, dejar vacío.
VITE_API_PATH_PREFIX=

# Base path donde se sirve el bundle.
#   - Netlify / Vercel / raíz: /
#   - VPS bajo /telegramFront/: /telegramFront/
VITE_BASE=/

# URLs legacy usadas en const/globales.ts.
VITE_DESARROLLO=http://127.0.0.1:4001
VITE_PRODUCCION=https://your-service.onrender.com
