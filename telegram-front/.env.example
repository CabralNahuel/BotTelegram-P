# Copiar a .env.development o .env.production y completar valores reales solo en tu máquina o en el servidor (no subir esos archivos).

# URL base del API Node (sin barra final). En local suele ser el puerto del bot.
VITE_API_BASE_URL=http://127.0.0.1:4001

# Si el proxy publica el API bajo un prefijo (ej. apis/infobot), sin barras al inicio/fin.
VITE_API_PATH_PREFIX=

# URLs legacy usadas en const/globales.ts (ajustar a tu entorno de demo).
VITE_DESARROLLO=http://127.0.0.1:4001
VITE_PRODUCCION=https://tu-dominio-de-demo.example.com
