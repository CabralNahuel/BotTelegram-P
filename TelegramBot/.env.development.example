NODE_ENV=development
PORT=4001

# Bot de Telegram (webhook mode). Para desarrollo local podés exponer el servidor con ngrok / cloudflared
# y usar esa URL HTTPS como PUBLIC_BASE_URL; o ignorar el bot y testear solo el API REST.
TELEGRAM_BOT_TOKEN=your_test_bot_token_here
TELEGRAM_WEBHOOK_SECRET=dev_secret_change_me
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app

# Database
HOST=localhost
MYSQL_USER=root
PASS=your_local_password
DATABASE=telegram_bot_dev
MYSQLPORT=3306
DB_SSL=false
JWT_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET
