NODE_ENV=production
PORT=4001
TELEGRAM_BOT_TOKEN=your_production_bot_token_here

# Opcional: duplica rutas bajo este prefijo si el proxy no quita /apis/infobot. La raíz (/login, /menu/) siempre existe.
API_PUBLIC_PREFIX=/apis/infobot

# Database
HOST=your_production_db_host
MYSQL_USER=your_production_db_user
PASS=your_production_db_password
DATABASE=your_production_db_name
MYSQLPORT=3306
# Generar valor largo y aleatorio (nunca commitear el valor real). Ej.: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET

# Opcional: si la columna de fecha en tabla estadisticas no es fecha_de_creacion (ver SHOW COLUMNS FROM estadisticas)
# ESTADISTICAS_FECHA_COLUMN=fecha
